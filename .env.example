# Snowflake Connection Credentials
# Copy this file to .env and fill in your actual values
# NEVER commit .env to version control

SNOWFLAKE_ACCOUNT=your_account_identifier.snowflakecomputing.com
SNOWFLAKE_USER=nyc_taxi_user
SNOWFLAKE_PASSWORD=your_secure_password_here
SNOWFLAKE_ROLE=nyc_taxi_role
SNOWFLAKE_WAREHOUSE=nyc_taxi_wh
SNOWFLAKE_DATABASE=nyc_taxi_lakehouse
SNOWFLAKE_SCHEMA=raw_data

# Airflow Configuration
AIRFLOW_HOME=/opt/airflow
AIRFLOW__CORE__EXECUTOR=LocalExecutor
AIRFLOW__DATABASE__SQL_ALCHEMY_CONN=postgresql+psycopg2://airflow:airflow@postgres/airflow
AIRFLOW__CORE__FERNET_KEY=your_fernet_key_here
AIRFLOW__WEBSERVER__SECRET_KEY=your_webserver_secret_key_here

# dbt Configuration
DBT_PROFILES_DIR=/opt/airflow/dbt_project
DBT_PROJECT_DIR=/opt/airflow/dbt_project
